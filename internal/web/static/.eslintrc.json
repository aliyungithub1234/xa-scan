{
  "env": {
    "browser": true,
    "es2021": true
  },
  "globals": {
    "openVulnModal": "readonly",
    "closeModal": "readonly",
    "closeHelpModal": "readonly",
    "scrollToBottom": "readonly",
    "loadLastScan": "readonly",
    "hideNewScanPanel": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "caughtErrorsIgnorePattern": ".*" }]
  }
}
